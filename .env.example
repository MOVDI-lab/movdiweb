# =====================================================================
# MOVDI · Variables de entorno (plantilla)
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y NUNCA debe subirse al repositorio.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase — valores PÚBLICOS (se exponen al navegador, es seguro)
# Project: movdi-web (ref bspnyanetywxysygnkaw)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://bspnyanetywxysygnkaw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx_reemplazar"

# ---------------------------------------------------------------------
# Supabase — clave SECRETA (solo servidor). NUNCA con prefijo NEXT_PUBLIC.
# Se usa para operaciones administrativas del lado del servidor.
# Tómala de: Supabase Dashboard > Project Settings > API > service_role
# ---------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY="reemplazar_service_role_key"

# ---------------------------------------------------------------------
# Formspree — endpoint para los formularios de contacto/cotización.
# Sin prefijo NEXT_PUBLIC: las peticiones se hacen desde el servidor.
# ---------------------------------------------------------------------
FORMSPREE_ENDPOINT="https://formspree.io/f/mrerqovl"

# Correo que recibe copia de las solicitudes de cotización.
COTIZAR_CC_EMAIL="daniela@movdi.mx"

# ---------------------------------------------------------------------
# URL pública del sitio (para metadatos OG/canonical absolutos)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://movdi.mx"
